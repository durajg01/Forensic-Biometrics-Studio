/src-tauri/bin/pyfing_enhance*.exe
/src-tauri/bin/pyfing_enhance
/src-tauri/bin/pyfing_enhance-*

# local installer / toolchain artifacts (not project files)
/Setup.msix
/rustup-init.exe
